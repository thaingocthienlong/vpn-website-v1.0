    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.0",
    "lightswind": "^3.1.21",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-cloudinary": "^6.17.5",
    "next-intl": "^4.8.2",
    "nodemailer": "^8.0.1",
    "prisma": "^7.3.0",
    "react": "19.2.3",
