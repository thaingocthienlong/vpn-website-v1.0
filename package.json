{
  "name": "new",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "mcp:chrome": "node scripts/mcp-chrome.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate:json:audit": "ts-node --project scripts/tsconfig.json migrate/migrate-from-json.ts --audit-only",
    "migrate:json:dry-run": "ts-node --project scripts/tsconfig.json migrate/migrate-from-json.ts --dry-run",
    "migrate:json": "ts-node --project scripts/tsconfig.json migrate/migrate-from-json.ts",
    "verify:db:json": "ts-node --project scripts/tsconfig.json scripts/verify-database.ts",
    "plesk-install": "npm install --omit=dev",
    "plesk-db-push": "./node_modules/.bin/prisma db push",
    "plesk-build": "./node_modules/.bin/prisma generate && rm -rf .next && NODE_OPTIONS=\"--max-old-space-size=512\" NEXT_TELEMETRY_DISABLED=1 ./node_modules/.bin/next build",
    "build-standalone": "node scripts/build-standalone.mjs",
    "plesk-standalone-prisma": "prisma generate"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-react": "^11.0.1",
