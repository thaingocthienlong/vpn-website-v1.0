generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("CONTENT_EDITOR")
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[]
  media     Media[]
  pages     Page[]
  posts     Post[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  name_en     String?
  slug        String   @unique
  type        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]
  posts       Post[]

  @@map("categories")
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  posts     PostTag[]

  @@map("tags")
}

model Post {
  id                 String    @id @default(uuid())
  title              String
  title_en           String?
  slug               String    @unique
  excerpt            String?
  excerpt_en         String?
  content            String
  content_en         String?
  featuredImageId    String?
  featuredImageId_en String?
  categoryId         String
  authorId           String
  type               String    @default("ORIGINAL")
  sourceUrl          String?
  isFeatured         Boolean   @default(false)
  isPublished        Boolean   @default(false)
  publishedAt        DateTime?
  viewCount          Int       @default(0)
  sortOrder          Int       @default(0)
  metaTitle          String?
  metaTitle_en       String?
  metaDescription    String?
  metaDescription_en String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tags               PostTag[]
  author             User      @relation(fields: [authorId], references: [id])
  category           Category  @relation(fields: [categoryId], references: [id])
  featuredImage_en   Media?    @relation("PostFeaturedImageEn", fields: [featuredImageId_en], references: [id])
  featuredImage      Media?    @relation("PostFeaturedImage", fields: [featuredImageId], references: [id])

  @@map("posts")
}

model PostTag {
  postId String
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model Page {
  id                 String   @id @default(uuid())
  title              String
  title_en           String?
  slug               String   @unique
  content            String
  content_en         String?
  featuredImageId    String?
  featuredImageId_en String?
  template           String   @default("default")
  authorId           String
  isPublished        Boolean  @default(false)
  sortOrder          Int      @default(0)
  metaTitle          String?
  metaTitle_en       String?
  metaDescription    String?
  metaDescription_en String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  author             User     @relation(fields: [authorId], references: [id])
  featuredImage_en   Media?   @relation("PageFeaturedImageEn", fields: [featuredImageId_en], references: [id])
  featuredImage      Media?   @relation("PageFeaturedImage", fields: [featuredImageId], references: [id])

  @@map("pages")
}

model Department {
  id          String   @id @default(uuid())
  name        String
  name_en     String?
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff[]

  @@map("departments")
}

model StaffType {
  id         String   @id @default(uuid())
  name       String
  name_en    String?
  level      Int
  isAdvisory Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  staff      Staff[]

  @@map("staff_types")
}

model Staff {
  id           String      @id @default(uuid())
  name         String
  name_en      String?
  title        String?
  title_en     String?
  bio          String?
  bio_en       String?
  avatarId     String?
  avatarId_en  String?
  email        String?
  phone        String?
  staffTypeId  String
  departmentId String?
  sortOrder    Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  department   Department? @relation(fields: [departmentId], references: [id])
  staffType    StaffType   @relation(fields: [staffTypeId], references: [id])
  avatar_en    Media?      @relation("StaffAvatarEn", fields: [avatarId_en], references: [id])
  avatar       Media?      @relation("StaffAvatar", fields: [avatarId], references: [id])

  @@map("staff")
}

model Partner {
  id             String          @id @default(uuid())
  name           String
  name_en        String?
  logoId         String?
  logoId_en      String?
  website        String?
  description    String?
  description_en String?
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  courses        CoursePartner[]
  logo_en        Media?          @relation("PartnerLogoEn", fields: [logoId_en], references: [id])
  logo           Media?          @relation("PartnerLogo", fields: [logoId], references: [id])

  @@map("partners")
}

model Course {
  id                 String          @id @default(uuid())
  title              String
  title_en           String?
  slug               String          @unique
  excerpt            String?
  excerpt_en         String?
  featuredImageId    String?
  featuredImageId_en String?
  categoryId         String?
  type               String
  authorId           String
  isFeatured         Boolean         @default(false)
  isPublished        Boolean         @default(false)
  publishedAt        DateTime?
  isRegistrationOpen Boolean         @default(true)
  viewCount          Int             @default(0)
  sortOrder          Int             @default(0)
  metaTitle          String?
  metaTitle_en       String?
  metaDescription    String?
  metaDescription_en String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  contacts           ContactForm[]
  partners           CoursePartner[]
  author             User            @relation(fields: [authorId], references: [id])
  category           Category?       @relation(fields: [categoryId], references: [id])
  featuredImage_en   Media?          @relation("CourseFeaturedImageEn", fields: [featuredImageId_en], references: [id])
  featuredImage      Media?          @relation("CourseFeaturedImage", fields: [featuredImageId], references: [id])
  registrations      Registration[]

  @@map("courses")
}

model CoursePartner {
  courseId  String
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([courseId, partnerId])
  @@map("course_partners")
}

model ContentSection {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  sectionKey String
  title      String
  title_en   String?
  content    String
  content_en String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId, sectionKey])
  @@index([entityType, entityId])
  @@map("content_sections")
}

model Registration {
  id           String   @id @default(uuid())
  fullName     String
  email        String
  phone        String
  organization String?
  position     String?
  courseId     String
  message      String?
  status       String   @default("NEW")
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  course       Course   @relation(fields: [courseId], references: [id])

  @@map("registrations")
}

model ContactForm {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  phone     String
  subject   String?
  message   String
  courseId  String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course?  @relation(fields: [courseId], references: [id])

  @@map("contact_forms")
}

model Media {
  id             String    @id @default(uuid())
  publicId       String?   @unique
  filename       String
  format         String?
  resourceType   String?
  url            String
  secureUrl      String?
  mimeType       String?
  size           Int
  width          Int?
  height         Int?
  alt            String?
  alt_en         String?
  uploadedById   String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  courseImagesEn Course[]  @relation("CourseFeaturedImageEn")
  courseImages   Course[]  @relation("CourseFeaturedImage")
  uploadedBy     User      @relation(fields: [uploadedById], references: [id])
  pageImagesEn   Page[]    @relation("PageFeaturedImageEn")
  pageImages     Page[]    @relation("PageFeaturedImage")
  partnerLogosEn Partner[] @relation("PartnerLogoEn")
  partnerLogos   Partner[] @relation("PartnerLogo")
  postImagesEn   Post[]    @relation("PostFeaturedImageEn")
  postImages     Post[]    @relation("PostFeaturedImage")
  staffAvatarsEn Staff[]   @relation("StaffAvatarEn")
  staffAvatars   Staff[]   @relation("StaffAvatar")

  @@map("media")
}

model Service {
  id              String   @id @default(uuid())
  title           String
  title_en        String?
  slug            String   @unique
  excerpt         String?
  excerpt_en      String?
  thumbnailUrl    String?
  isFeatured      Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  metaTitle       String?
  metaDescription String?
  viewCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("services")
}

model Video {
  id           String   @id @default(uuid())
  title        String
  title_en     String?
  thumbnailUrl String?
  videoUrl     String
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("videos")
}

model Configuration {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   @default("STRING")
  group       String   @default("general")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("configurations")
}

model HomepageSection {
  id          String   @id @default(uuid())
  sectionKey  String
  locale      String
  title       String?
  title_en    String?
  subtitle    String?
  subtitle_en String?
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sectionKey, locale])
  @@map("homepage_sections")
}

model MenuItem {
  id        String     @id @default(uuid())
  label     String
  label_en  String?
  url       String
  locale    String
  parentId  String?
  icon      String?
  target    String     @default("_self")
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children  MenuItem[] @relation("MenuHierarchy")

  @@map("menu_items")
}
